dotnet_diagnostic.VSTHRD107.severity = warning

# Assert thread affinity unconditionally
dotnet_diagnostic.VSTHRD108.severity = warning

# Switch instead of assert in async methods
dotnet_diagnostic.VSTHRD109.severity = warning

# Observe result of async calls
dotnet_diagnostic.VSTHRD110.severity = warning

# Use ConfigureAwait(bool) — aligned with CA2007 (now also warning)
dotnet_diagnostic.VSTHRD111.severity = warning

# Implement System.IAsyncDisposable
dotnet_diagnostic.VSTHRD112.severity = warning

# Check for System.IAsyncDisposable
dotnet_diagnostic.VSTHRD113.severity = warning

# Avoid returning a null Task
dotnet_diagnostic.VSTHRD114.severity = warning

# Use Async suffix naming convention
dotnet_diagnostic.VSTHRD200.severity = warning


[**/Extensions/*.cs]
# C# 14 introduces 'extension' methods, which would conflict with this rule.
# The rule conflicts with outdated analyzers that do not recognize 'extension' methods and incorrectly flag them.
dotnet_diagnostic.CA1708.severity = none
