root = true

# ────────────────────────────────────────────────────────────────────────────────
# § 1  Universal defaults
# ────────────────────────────────────────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = auto
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# ────────────────────────────────────────────────────────────────────────────────
# § 2  File-type overrides
# ────────────────────────────────────────────────────────────────────────────────
[*.sln]
indent_style = tab

[*.{csproj,vbproj,vcxproj,vcxproj.filters,proj,projitems,shproj,props,targets}]
indent_size = 2

[*.{json,json5,yml,yaml,config}]
indent_size = 2

[{package-lock.json,yarn.lock,pnpm-lock.yaml}]
indent_size = 2
insert_final_newline = true

[*.{xml,xaml,axaml,resx,settings}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{sh,ps1,psm1,psd1}]
end_of_line = lf

[*.{cmd,bat}]
end_of_line = crlf

[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ────────────────────────────────────────────────────────────────────────────────
# § 3  C#  —  all remaining rules apply to *.cs only
#
#   IMPORTANT: Directory.Build.props must contain:
#     <AnalysisMode>All</AnalysisMode>
#     <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
#
#   That enables every CA/IDE rule at its SDK-recommended severity.
#   Everything below is either a genuine deviation from those recommendations,
#   a naming convention, a formatting preference, or a severity promotion.
#   Do NOT restate SDK defaults here — they create silent divergence on SDK updates.
# ────────────────────────────────────────────────────────────────────────────────
[*.cs]

# ── 3.1  Namespace & imports ──────────────────────────────────────────────────
csharp_style_namespace_declarations = file_scoped:error
csharp_using_directive_placement = inside_namespace:error
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = true
dotnet_style_namespace_match_folder = true:error

# ── 3.2  Accessibility & modifiers ───────────────────────────────────────────
dotnet_style_require_accessibility_modifiers = for_non_interface_members:error
csharp_preferred_modifier_order = public,private,protected,internal,file,static,extern,new,virtual,abstract,sealed,override,readonly,unsafe,required,volatile,async:error
dotnet_style_readonly_field = true:error
csharp_prefer_static_local_function = true:warning
csharp_prefer_static_anonymous_function = true:warning
dotnet_style_qualification_for_field = false:error
dotnet_style_qualification_for_property = false:error
dotnet_style_qualification_for_method = false:error
dotnet_style_qualification_for_event = false:error

# ── 3.3  Type names — keywords vs BCL ────────────────────────────────────────
dotnet_style_predefined_type_for_locals_parameters_members = true:error
dotnet_style_predefined_type_for_member_access = true:error

# ── 3.4  var usage ────────────────────────────────────────────────────────────
csharp_style_var_for_built_in_types = true:error
csharp_style_var_when_type_is_apparent = true:error
csharp_style_var_elsewhere = true:warning

# ── 3.5  Null handling ────────────────────────────────────────────────────────
dotnet_style_null_propagation = true:error
dotnet_style_coalesce_expression = true:error
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:error
csharp_style_conditional_delegate_call = true:error
csharp_style_prefer_null_check_over_type_check = true:error
csharp_style_prefer_parameter_null_checking = true:error

# ── 3.6  Pattern matching ─────────────────────────────────────────────────────
csharp_style_prefer_pattern_matching = true:error
csharp_style_pattern_matching_over_as_with_null_check = true:error
csharp_style_pattern_matching_over_is_with_cast_check = true:error
csharp_style_prefer_not_pattern = true:error
csharp_style_prefer_switch_expression = true:error
csharp_style_prefer_extended_property_pattern = true:warning
csharp_style_prefer_list_pattern = true:warning

# ── 3.7  Expressions & simplifications ───────────────────────────────────────
csharp_style_throw_expression = true:error
csharp_style_inlined_variable_declaration = true:error
csharp_style_deconstructed_variable_declaration = true:warning
csharp_style_prefer_tuple_swap = true:warning
csharp_style_prefer_range_operator = true:error
csharp_style_prefer_index_operator = true:error
dotnet_style_prefer_conditional_expression_over_assignment = true:warning   # not :error — ternary chains hurt readability
dotnet_style_prefer_conditional_expression_over_return = true:warning       # same rationale
dotnet_style_prefer_compound_assignment = true:error
dotnet_style_prefer_auto_properties = true:error
dotnet_style_object_initializer = true:error
dotnet_style_collection_initializer = true:error
dotnet_style_prefer_inferred_tuple_names = true:warning
dotnet_style_explicit_tuple_names = true:error
dotnet_style_prefer_simplified_interpolation = true:warning
dotnet_style_prefer_simplified_boolean_expressions = true:error
dotnet_style_prefer_foreach_explicit_cast_in_source = when_strongly_typed:warning
csharp_style_prefer_method_group_conversion = true:warning
csharp_style_prefer_local_over_anonymous_function = true:warning
csharp_style_unused_value_assignment_preference = discard_variable:warning
csharp_style_unused_value_expression_statement_preference = discard_variable:warning

# ── 3.8  Modern C# features (12–15) ──────────────────────────────────────────
# Primary constructors: suggestion only — noisy on DI-heavy types
csharp_style_prefer_primary_constructors = true:suggestion
csharp_style_prefer_readonly_struct = true:error
csharp_style_prefer_readonly_struct_member = true:error
csharp_style_prefer_utf8_string_literals = true:error
csharp_style_prefer_raw_string_literals = true:warning
csharp_style_implicit_object_creation_when_type_is_apparent = true:error

# C# 14: field keyword in property bodies
dotnet_style_prefer_field_keyword = true:error

# C# 12–15: collection expressions — [with(capacity:)] and spread operator.
# IDE0300–IDE0305 are on via AnalysisMode=All.
# The [with(capacity:)] construction-argument form has no dedicated IDE rule yet;
# CA1861 + CA1825 catch the allocation anti-patterns it replaces.
dotnet_style_prefer_collection_expression = true:error

# ── 3.9  Expression bodies
#         Kept at :silent — body vs block is a readability call per member.
#         Enforce via code review, not the compiler.
# ─────────────────────────────────────────────────────────────────────────────
csharp_style_expression_bodied_constructors = true:silent
csharp_style_expression_bodied_methods = true:silent
csharp_style_expression_bodied_operators = true:silent
csharp_style_expression_bodied_properties = true:silent
csharp_style_expression_bodied_indexers = true:silent
csharp_style_expression_bodied_accessors = true:silent
csharp_style_expression_bodied_lambdas = true:silent
csharp_style_expression_bodied_local_functions = true:silent

# ── 3.10  using statements & braces ──────────────────────────────────────────
csharp_prefer_simple_using_statement = true:error
csharp_prefer_braces = true:error
csharp_preserve_single_line_blocks = true
csharp_preserve_single_line_statements = false

# ── 3.12  Brace & newline placement ──────────────────────────────────────────
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_before_members_in_anonymous_types = true
csharp_new_line_between_query_expression_clauses = true

# ── 3.13  Indentation ─────────────────────────────────────────────────────────
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
csharp_indent_case_contents_when_block = false
csharp_indent_labels = one_less_than_current
csharp_indent_block_contents = true
csharp_indent_braces = false

# ── 3.14  Spacing ─────────────────────────────────────────────────────────────
csharp_space_after_cast = true
csharp_space_after_keywords_in_control_flow_statements = true
csharp_space_around_binary_operators = before_and_after
csharp_space_around_declaration_statements = false
csharp_space_after_colon_in_inheritance_clause = true
csharp_space_before_colon_in_inheritance_clause = true
csharp_space_after_comma = true
csharp_space_after_dot = false
csharp_space_after_semicolon_in_for_statement = true
csharp_space_before_semicolon_in_for_statement = false
csharp_space_before_open_square_brackets = false
csharp_space_between_empty_square_brackets = false
csharp_space_between_square_brackets = false
csharp_space_between_method_call_parameter_list_parentheses = false
csharp_space_between_method_declaration_parameter_list_parentheses = false
csharp_space_between_method_call_empty_parameter_list_parentheses = false
csharp_space_between_method_declaration_empty_parameter_list_parentheses = false
csharp_space_between_method_call_name_and_opening_parenthesis = false
csharp_space_between_method_declaration_name_and_open_parenthesis = false
csharp_space_between_parentheses = false

# ── 3.15  Formatting — delegated entirely to `dotnet format` / CI ─────────────
dotnet_diagnostic.IDE0055.severity = none

# ────────────────────────────────────────────────────────────────────────────────
# § 4  Naming conventions
#       Symbols → Styles → Rules, in that order.
#       All naming violations are :error — wrong names break grep, tooling & docs.
# ────────────────────────────────────────────────────────────────────────────────

# Styles
dotnet_naming_style.pascal_case.capitalization = pascal_case
dotnet_naming_style.camel_case.capitalization = camel_case
dotnet_naming_style.underscore_camel.required_prefix = _
dotnet_naming_style.underscore_camel.capitalization = camel_case
dotnet_naming_style.begins_with_i.required_prefix = I
dotnet_naming_style.begins_with_i.capitalization = pascal_case
dotnet_naming_style.begins_with_t.required_prefix = T
dotnet_naming_style.begins_with_t.capitalization = pascal_case
dotnet_naming_style.ends_with_async.required_suffix = Async
dotnet_naming_style.ends_with_async.capitalization = pascal_case

# Symbols
dotnet_naming_symbols.interfaces.applicable_kinds = interface
dotnet_naming_symbols.interfaces.applicable_accessibilities = *
dotnet_naming_symbols.type_parameters.applicable_kinds = type_parameter
dotnet_naming_symbols.type_parameters.applicable_accessibilities = *
dotnet_naming_symbols.types.applicable_kinds = class, struct, enum, delegate, record
dotnet_naming_symbols.types.applicable_accessibilities = *
dotnet_naming_symbols.async_methods.applicable_kinds = method
dotnet_naming_symbols.async_methods.required_modifiers = async
dotnet_naming_symbols.async_methods.applicable_accessibilities = *
dotnet_naming_symbols.constants.applicable_kinds = field
dotnet_naming_symbols.constants.required_modifiers = const
dotnet_naming_symbols.constants.applicable_accessibilities = *
dotnet_naming_symbols.static_readonly_fields.applicable_kinds = field
dotnet_naming_symbols.static_readonly_fields.required_modifiers = static, readonly
dotnet_naming_symbols.static_readonly_fields.applicable_accessibilities = *
dotnet_naming_symbols.static_fields.applicable_kinds = field
dotnet_naming_symbols.static_fields.required_modifiers = static
dotnet_naming_symbols.static_fields.applicable_accessibilities = *
dotnet_naming_symbols.non_field_members.applicable_kinds = property, method, event
dotnet_naming_symbols.non_field_members.applicable_accessibilities = *
dotnet_naming_symbols.public_fields.applicable_kinds = field
dotnet_naming_symbols.public_fields.applicable_accessibilities = public, internal, protected, protected_internal
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private, private_protected
dotnet_naming_symbols.private_fields.required_modifiers = none
dotnet_naming_symbols.parameters.applicable_kinds = parameter
dotnet_naming_symbols.parameters.applicable_accessibilities = *
dotnet_naming_symbols.locals.applicable_kinds = local
dotnet_naming_symbols.locals.applicable_accessibilities = *
dotnet_naming_symbols.local_functions.applicable_kinds = local_function
dotnet_naming_symbols.local_functions.applicable_accessibilities = *

# Rules
dotnet_naming_rule.interfaces_must_begin_with_i.symbols = interfaces
dotnet_naming_rule.interfaces_must_begin_with_i.style = begins_with_i
dotnet_naming_rule.interfaces_must_begin_with_i.severity = error
dotnet_naming_rule.type_parameters_must_begin_with_t.symbols = type_parameters
dotnet_naming_rule.type_parameters_must_begin_with_t.style = begins_with_t
dotnet_naming_rule.type_parameters_must_begin_with_t.severity = error
dotnet_naming_rule.types_must_be_pascal_case.symbols = types
dotnet_naming_rule.types_must_be_pascal_case.style = pascal_case
dotnet_naming_rule.types_must_be_pascal_case.severity = error
dotnet_naming_rule.async_methods_end_with_async.symbols = async_methods
dotnet_naming_rule.async_methods_end_with_async.style = ends_with_async
dotnet_naming_rule.async_methods_end_with_async.severity = error
dotnet_naming_rule.non_field_members_must_be_pascal_case.symbols = non_field_members
dotnet_naming_rule.non_field_members_must_be_pascal_case.style = pascal_case
dotnet_naming_rule.non_field_members_must_be_pascal_case.severity = error
dotnet_naming_rule.constants_should_be_pascal_case.symbols = constants
dotnet_naming_rule.constants_should_be_pascal_case.style = pascal_case
dotnet_naming_rule.constants_should_be_pascal_case.severity = error
dotnet_naming_rule.static_readonly_fields_should_be_pascal_case.symbols = static_readonly_fields
dotnet_naming_rule.static_readonly_fields_should_be_pascal_case.style = pascal_case
dotnet_naming_rule.static_readonly_fields_should_be_pascal_case.severity = error
dotnet_naming_rule.static_fields_must_be_underscore_camel.symbols = static_fields
dotnet_naming_rule.static_fields_must_be_underscore_camel.style = underscore_camel
dotnet_naming_rule.static_fields_must_be_underscore_camel.severity = error
dotnet_naming_rule.public_fields_should_be_pascal_case.symbols = public_fields
dotnet_naming_rule.public_fields_should_be_pascal_case.style = pascal_case
dotnet_naming_rule.public_fields_should_be_pascal_case.severity = error
dotnet_naming_rule.private_fields_must_be_underscore_camel.symbols = private_fields
dotnet_naming_rule.private_fields_must_be_underscore_camel.style = underscore_camel
dotnet_naming_rule.private_fields_must_be_underscore_camel.severity = error
dotnet_naming_rule.parameters_must_be_camel_case.symbols = parameters
dotnet_naming_rule.parameters_must_be_camel_case.style = camel_case
dotnet_naming_rule.parameters_must_be_camel_case.severity = error
dotnet_naming_rule.locals_must_be_camel_case.symbols = locals
dotnet_naming_rule.locals_must_be_camel_case.style = camel_case
dotnet_naming_rule.locals_must_be_camel_case.severity = error
dotnet_naming_rule.local_functions_must_be_pascal_case.symbols = local_functions
dotnet_naming_rule.local_functions_must_be_pascal_case.style = pascal_case
dotnet_naming_rule.local_functions_must_be_pascal_case.severity = error

# ────────────────────────────────────────────────────────────────────────────────
# § 5  Nullable reference types — all violations are errors
#       CS86xx are off by default; AnalysisMode=All does not cover them.
# ────────────────────────────────────────────────────────────────────────────────
dotnet_diagnostic.CS8600.severity = error
dotnet_diagnostic.CS8601.severity = error
dotnet_diagnostic.CS8602.severity = error
dotnet_diagnostic.CS8603.severity = error
dotnet_diagnostic.CS8604.severity = error
dotnet_diagnostic.CS8609.severity = error
dotnet_diagnostic.CS8611.severity = error
dotnet_diagnostic.CS8618.severity = error
dotnet_diagnostic.CS8619.severity = error
dotnet_diagnostic.CS8620.severity = error
dotnet_diagnostic.CS8625.severity = error
dotnet_diagnostic.CS8714.severity = error

# ────────────────────────────────────────────────────────────────────────────────
# § 6  Category-level severity floors
#       AnalysisMode=All sets most of these; listed here as an explicit contract
#       so team members know what the floor is without reading Directory.Build.props.
# ────────────────────────────────────────────────────────────────────────────────
dotnet_analyzer_diagnostic.category-Style.severity = warning
dotnet_analyzer_diagnostic.category-CodeQuality.severity = warning
dotnet_analyzer_diagnostic.category-Design.severity = warning
dotnet_analyzer_diagnostic.category-Documentation.severity = warning
dotnet_analyzer_diagnostic.category-Globalization.severity = warning
dotnet_analyzer_diagnostic.category-Interoperability.severity = warning
dotnet_analyzer_diagnostic.category-Maintainability.severity = warning
dotnet_analyzer_diagnostic.category-Naming.severity = warning
dotnet_analyzer_diagnostic.category-Performance.severity = warning
dotnet_analyzer_diagnostic.category-Reliability.severity = warning
dotnet_analyzer_diagnostic.category-Security.severity = error
dotnet_analyzer_diagnostic.category-Usage.severity = warning
dotnet_analyzer_diagnostic.category-Publish.severity = warning

# ────────────────────────────────────────────────────────────────────────────────
# § 7  IDE diagnostic overrides
#       Only rules that deviate from AnalysisMode=All recommendations are listed.
#       If a rule is at the right severity by default, it is not mentioned here.
# ────────────────────────────────────────────────────────────────────────────────

# Silenced — expression bodies are a readability call, not a correctness one (§ 3.9)
dotnet_diagnostic.IDE0021.severity = silent
dotnet_diagnostic.IDE0022.severity = silent
dotnet_diagnostic.IDE0023.severity = silent
dotnet_diagnostic.IDE0024.severity = silent
dotnet_diagnostic.IDE0025.severity = silent
dotnet_diagnostic.IDE0026.severity = silent
dotnet_diagnostic.IDE0027.severity = silent
dotnet_diagnostic.IDE0053.severity = silent
dotnet_diagnostic.IDE0061.severity = silent

# Silenced — expression value discard is a style choice enforced via review
dotnet_diagnostic.IDE0058.severity = silent

# Silenced — file headers: promote to :warning once team adopts a standard template
dotnet_diagnostic.IDE0073.severity = silent

# Silenced — IDE0046 conditional return: causes readability issues in guard-clause-heavy code
dotnet_diagnostic.IDE0046.severity = silent

# Silenced — primary constructors: team discretion, already :suggestion in § 3.8
dotnet_diagnostic.IDE0290.severity = silent

# Silenced — coalesce-over-throw is covered by the throw-expression rules already
dotnet_diagnostic.IDE0270.severity = silent

# Silenced — block-scoped namespace is dead with file_scoped preference in § 3.1
dotnet_diagnostic.IDE0160.severity = none

# Silenced — formatting is delegated to `dotnet format` / CI (§ 3.15)
dotnet_diagnostic.IDE0055.severity = none

# Silenced — blank line after arrow expression clause (noisy false-positive rate)
dotnet_diagnostic.IDE2006.severity = none

# Silenced — XML doc comments: team choice, not a correctness issue
dotnet_diagnostic.CS1591.severity = silent

# ────────────────────────────────────────────────────────────────────────────────
# § 8  CA Design (CA1xxx)
# ────────────────────────────────────────────────────────────────────────────────

# Suppressed — not applicable / too opinionated for modern .NET
dotnet_diagnostic.CA1014.severity = silent   # CLSCompliant not applicable for modern apps
dotnet_diagnostic.CA1017.severity = silent   # ComVisible — COM interop is rare
dotnet_diagnostic.CA1028.severity = silent   # Enum storage: allow byte/short for flags
dotnet_diagnostic.CA1030.severity = silent   # Use events — too broad
dotnet_diagnostic.CA1034.severity = silent   # Nested types — commonly accepted pattern
dotnet_diagnostic.CA1040.severity = silent   # Empty interfaces — marker interfaces are valid

# ────────────────────────────────────────────────────────────────────────────────
# § 9  CA Performance (CA18xx)
# ────────────────────────────────────────────────────────────────────────────────

# Security-level promotion
dotnet_diagnostic.CA1856.severity = error    # Incorrect ConstantExpected usage

# ────────────────────────────────────────────────────────────────────────────────
# § 10  CA Reliability / Usage (CA2xxx)
# ────────────────────────────────────────────────────────────────────────────────

# Security-level promotion
dotnet_diagnostic.CA2100.severity = error    # Review SQL queries for injection
dotnet_diagnostic.CA2252.severity = error    # Opt in to preview features before use

# ────────────────────────────────────────────────────────────────────────────────
# § 11  CA Security (CA5xxx + CA23xx insecure deserializers)
#       The category floor is already :error (§ 6).
#       These explicit entries document intent and survive category-floor changes.
# ────────────────────────────────────────────────────────────────────────────────
dotnet_diagnostic.CA2300.severity = error    # BinaryFormatter — do not use
dotnet_diagnostic.CA2301.severity = error    # BinaryFormatter without Binder
dotnet_diagnostic.CA2302.severity = error    # BinaryFormatter Binder not set
dotnet_diagnostic.CA2305.severity = error    # LosFormatter insecure deserializer
dotnet_diagnostic.CA2310.severity = error    # NetDataContractSerializer — do not use
dotnet_diagnostic.CA2311.severity = error    # NetDataContractSerializer without Binder
dotnet_diagnostic.CA2312.severity = error    # NetDataContractSerializer Binder not set
dotnet_diagnostic.CA2315.severity = error    # ObjectStateFormatter insecure
dotnet_diagnostic.CA2321.severity = error    # JavaScriptSerializer + SimpleTypeResolver
dotnet_diagnostic.CA2322.severity = error    # JavaScriptSerializer initialized with SimpleTypeResolver
dotnet_diagnostic.CA2326.severity = error    # TypeNameHandling other than None
dotnet_diagnostic.CA2327.severity = error    # Insecure JsonSerializerSettings
dotnet_diagnostic.CA2328.severity = error    # JsonSerializerSettings not verified secure
dotnet_diagnostic.CA2329.severity = error    # JsonSerializer insecure config on deserialize
dotnet_diagnostic.CA2330.severity = error    # JsonSerializer insecure config not verified
dotnet_diagnostic.CA5350.severity = error    # Weak crypto — 3DES, RC2
dotnet_diagnostic.CA5351.severity = error    # Broken crypto — MD5, DES
dotnet_diagnostic.CA5359.severity = error    # Certificate validation disabled
dotnet_diagnostic.CA5360.severity = error    # Dangerous methods in deserialization
dotnet_diagnostic.CA5364.severity = error    # Deprecated security protocols (SSL3, TLS 1.0/1.1)
dotnet_diagnostic.CA5369.severity = error    # XmlReader required for Deserialize
dotnet_diagnostic.CA5370.severity = error    # XmlReader required for validating reader
dotnet_diagnostic.CA5371.severity = error    # XmlReader required for schema read
dotnet_diagnostic.CA5372.severity = error    # XmlReader required for XPathDocument
dotnet_diagnostic.CA5373.severity = error    # Obsolete key derivation function
dotnet_diagnostic.CA5374.severity = error    # XslTransform — do not use
dotnet_diagnostic.CA5378.severity = error    # ServicePointManagerSecurityProtocols disabled
dotnet_diagnostic.CA5379.severity = error    # Key derivation algorithm not sufficiently strong
dotnet_diagnostic.CA5384.severity = error    # DSA — do not use
dotnet_diagnostic.CA5385.severity = error    # RSA key size < 2048 bits
dotnet_diagnostic.CA5397.severity = error    # Deprecated SslProtocols values
dotnet_diagnostic.CA5399.severity = error    # HttpClient CRL checks disabled

# ────────────────────────────────────────────────────────────────────────────────
# § 12  CA Naming overrides
# ────────────────────────────────────────────────────────────────────────────────

# none — conflicts with _camelCase convention in § 4
dotnet_diagnostic.CA1707.severity = none     # Identifiers should not contain underscores

# none — conflicts with custom API naming standards
dotnet_diagnostic.CA1711.severity = none     # Identifiers should not have incorrect suffix

# none — antiparallel with CA1027; resolved by keeping CA1027 at warning
dotnet_diagnostic.CA2217.severity = none     # Do not mark enums with FlagsAttribute

# none — too opinionated for modern APIs
dotnet_diagnostic.CA2225.severity = none     # Operator overloads have named alternates

# silent — identifiers matching keywords is too noisy in practice
dotnet_diagnostic.CA1716.severity = silent   # Identifiers should not match keywords

# ────────────────────────────────────────────────────────────────────────────────
# § 13  VSTHRD async/threading rules
#         All are :warning; the category floor does not cover VSTHRD rules.
# ────────────────────────────────────────────────────────────────────────────────
dotnet_diagnostic.VSTHRD001.severity = warning
dotnet_diagnostic.VSTHRD002.severity = warning
dotnet_diagnostic.VSTHRD003.severity = warning
dotnet_diagnostic.VSTHRD010.severity = warning
dotnet_diagnostic.VSTHRD011.severity = warning
dotnet_diagnostic.VSTHRD012.severity = warning
dotnet_diagnostic.VSTHRD100.severity = warning
dotnet_diagnostic.VSTHRD101.severity = warning
dotnet_diagnostic.VSTHRD102.severity = warning
dotnet_diagnostic.VSTHRD103.severity = warning
dotnet_diagnostic.VSTHRD104.severity = warning
dotnet_diagnostic.VSTHRD105.severity = warning
dotnet_diagnostic.VSTHRD106.severity = warning
dotnet_diagnostic.VSTHRD107.severity = warning
dotnet_diagnostic.VSTHRD108.severity = warning
dotnet_diagnostic.VSTHRD109.severity = warning
dotnet_diagnostic.VSTHRD110.severity = warning
dotnet_diagnostic.VSTHRD111.severity = warning   # ConfigureAwait — aligned with CA2007
dotnet_diagnostic.VSTHRD112.severity = warning
dotnet_diagnostic.VSTHRD113.severity = warning
dotnet_diagnostic.VSTHRD114.severity = warning
dotnet_diagnostic.VSTHRD115.severity = warning
dotnet_diagnostic.VSTHRD200.severity = warning   # Async suffix naming convention

# ────────────────────────────────────────────────────────────────────────────────
# § 14  Roslynator overrides
# ────────────────────────────────────────────────────────────────────────────────

# silent — already covered by CA1040 in § 8
dotnet_diagnostic.RCS1251.severity = silent

# ────────────────────────────────────────────────────────────────────────────────
# § 15  Per-folder overrides
# ────────────────────────────────────────────────────────────────────────────────
[**/Extensions/*.cs]
# C# 14+ introduces the `extension` keyword, which creates false-positive CA1708
# hits in analyzers that do not yet recognise the new syntax.
dotnet_diagnostic.CA1708.severity = none
